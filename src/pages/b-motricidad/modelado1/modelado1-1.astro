<script>
  const inicializarVideo = () => {
    // 1. Buscamos con el nuevo ID 'video-p'
    const video = document.getElementById('video-p') as HTMLVideoElement || document.querySelector('video');
    const btnPlay = document.getElementById('btn-play-pausa');
    const btnReplay = document.getElementById('btn-replay');

    // Consola para que veas qué está pasando realmente
    console.log("--- Reporte de Conexión ---");
    console.log("Video encontrado:", !!video);
    console.log("Botón Play encontrado:", !!btnPlay);
    console.log("Botón Replay encontrado:", !!btnReplay);

    if (video && btnPlay && btnReplay) {
      // Evento Play/Pausa
      btnPlay.onclick = () => {
        if (video.paused) {
          video.play();
          console.log("▶️ Reproduciendo...");
        } else {
          video.pause();
          console.log("⏸️ Pausado.");
        }
      };

      // Evento Replay
      btnReplay.onclick = () => {
        video.currentTime = 0;
        video.play();
        console.log("🔄 Replay activado.");
      };

      console.log("✅ ¡Todo listo! Los botones ya controlan el video.");
    } else {
      console.error("❌ Error: No se pudo establecer la conexión. Revisa que los IDs coincidan.");
    }
  };

  // Ejecución inmediata al cargar el componente
  inicializarVideo();

  // Refuerzo: Astro a veces necesita un pequeño respiro para juntar los componentes
  setTimeout(inicializarVideo, 500);
</script>