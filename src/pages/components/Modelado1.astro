<style>
    #ContenedorPrin{
        /* 3. Tu contenedor principal para diagramar los botones, textos,etc*/
    /* MEDIDAS EXACTAS*/
    width: 1400px;
    height: 650px;
    
    display: grid;
    /* 28 columnas(1fr para que sean iguales) */
    grid-template-columns: repeat(28, 1fr);
    /* 14 filas de igual tamaño */
    grid-template-rows: repeat(14, 1fr);
    background-image: 
      linear-gradient(to right, rgba(0,0,0,0.1) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(0,0,0,0.1) 1px, transparent 1px);
    background-size: calc(1400px / 28) calc(650px / 14);

    }

    #Pizarra {
        grid-column: 6/24;
        grid-row: 5/14;
        z-index: 1 ;
        display: flex;           /* Activa el modo flexible */
        justify-content: center; /* Centra horizontalmente (Eje X) */
        align-items: center;     /* Centra verticalmente (Eje Y) */
        padding-bottom: 25px;
    }
    .pizarraimg{
    object-fit: contain;
    }

    #barraizquierda{
        grid-column: 2/19;
        grid-row: 2/14;
        background-image: url('/public/barraizquierda.png');
        background-size: 100% 100%;
        background-position: center;
        background-repeat: no-repeat;
    }

    #Pestanatitulo{
        grid-column: 16/24;
        grid-row: 4/6;
        background-image: url(' /public/Pestanatitulo.svg');
        background-size: 100% 100%;
        background-position: center;
        background-repeat: no-repeat;
        
    }

    #ejer11{
        grid-column: 26/27;
        grid-row: 5/7;
        display: flex;           
        justify-content: center; 
        align-items: center;
    }

    #ejer12{
