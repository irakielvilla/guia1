        justify-content: center; 
        align-items: center;
    }
    #ejer14{
        grid-column: 26/27;
        grid-row: 12/13;
        display: flex;           
        justify-content: center; 
        align-items: center;
        z-index: 1;
    }
    .ejers{
        width: 100%;
    }
#barraderecha{
    padding-top: 20px;
    grid-column: 25/28;
    grid-row: 3/15;
    object-fit: none;
}
