---
// Componente: MenuDerechoNumeros.astro
const { currentNumber } = Astro.props;
const integerNumber = parseInt(currentNumber, 10);

// Astro decide qué bloque mostrar primero según el número de la página
const paginaInicialMenu = (integerNumber >= 0 && integerNumber <= 4) ? 1 : 2;
const { miejercicio } = Astro.props;


---

<div id="barraderecha" class="menu-interactivo-numeros" data-pagina-inicial={paginaInicialMenu}>
  
  <button id="btn-arriba" class="btn-flecha" title="Ver números anteriores">
    <img src="/barraderecha/arribadere.svg" alt="Flecha Arriba" />
  </button>

  <div id="grupo-numeros-1" class="bloque-numeros">
    <a href="/c-grafomotriz/numeros/numeros3-0/" class="btn-numero">
      <img src={integerNumber === 0 ? "/barraderecha/cerosin.svg" : "/barraderecha/ceron.svg"} alt="Número 0"/>
    </a>
    <a id="numero1" href="/c-grafomotriz/numeros/numeros3-1/" class="btn-numero">
      <img class="numerito1" src={integerNumber === 1 ? "/barraderecha/1sin.svg" : "/barraderecha/1n.svg"} alt="Número 1" />
    </a>
    <a href="/c-grafomotriz/numeros/numeros3-2/" class="btn-numero">
      <img src={integerNumber === 2 ? "/barraderecha/2sin.svg" : "/barraderecha/2n.svg"} alt="Número 2" />
    </a>
    <a href="/c-grafomotriz/numeros/numeros3-3/" class="btn-numero">
      <img src={integerNumber === 3 ? "/barraderecha/3sin.svg" : "/barraderecha/3n.svg"} alt="Número 3" />
    </a>
    <a href="/c-grafomotriz/numeros/numeros3-4/" class="btn-numero">
      <img src={integerNumber === 4 ? "/barraderecha/4sin.svg" : "/barraderecha/4n.svg"} alt="Número 4" />
    </a>
  </div>

  <div id="grupo-numeros-2" class="bloque-numeros oculto">
    <a href="/c-grafomotriz/numeros/numeros3-5/" class="btn-numero">
      <img src={integerNumber === 5 ? "/barraderecha/5sin.svg" : "/barraderecha/5n.svg"} alt="Número 5" />
    </a>
    <a href="/c-grafomotriz/numeros/numeros3-6/" class="btn-numero">
      <img src={integerNumber === 6 ? "/barraderecha/6sin.svg" : "/barraderecha/6n.svg"} alt="Número 6" />
    </a>
    <a href="/c-grafomotriz/numeros/numeros3-7/" class="btn-numero">
      <img src={integerNumber === 7 ? "/barraderecha/7sin.svg" : "/barraderecha/7n.svg"} alt="Número 7" />
    </a>
    <a href="/c-grafomotriz/numeros/numeros3-8/" class="btn-numero">
      <img src={integerNumber === 8 ? "/barraderecha/8sin.svg" : "/barraderecha/8n.svg"} alt="Número 8" />
    </a>
    <a href="/c-grafomotriz/numeros/numeros3-9/" class="btn-numero">
      <img src={integerNumber === 9 ? "/barraderecha/9sin.svg" : "/barraderecha/9n.svg"} alt="Número 9" />
    </a>
  </div>

  <button id="btn-abajo" class="btn-flecha" title="Ver siguientes números">
    <img src="/barraderecha/abajodere.svg" alt="Flecha Abajo" />
  </button>

</div>

<style>
  #btn-arriba{
    margin-bottom: -30%;
    width: 60%;
  }
  #btn-abajo{
    width: 60%;
  }


  .numerito1{
    height: 100% !important;
  }

  #numero1{
    height: 20% !important; 
  }
  /* Contenedor principal que se alinea con tu Grid */
  .menu-interactivo-numeros {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between !important;
    gap: 0px; /* Espacio entre flechas y números */
    width: 100%;
    height: 100%;
    grid-column: 26/31;
    grid-row: 5/15;
  }

  /* Estilos para limpiar los botones nativos y hacerlos interactivos */
  .btn-flecha {
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-flecha img {
    width: 22%; /* Ajusta el tamaño de tus flechas aquí */
    height: auto;
  }

  /* 🚀 LA MAGIA: Clase que desactiva la flecha cuando topamos el límite */
  .desactivado {
    opacity: 0; /* Se vuelve semitransparente */
    pointer-events: none; /* Bloquea el clic */
    cursor: default;
  }

  /* Estilos para los bloques de números */
  .bloque-numeros {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6.6%; /* Espacio entre cada número */
    width: 100%;
  }

  /* Clase para ocultar el bloque que no se está viendo */
  .oculto {
    display: none;
  }

  .btn-numero {
    display: block;
    width: 18%; /* Ajusta según lo ancho que quieras los números */
    transition: transform 0.2s ease;
  }

  .btn-numero img {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  /* Efecto sutil al pasar el mouse por encima de los números */
  .btn-numero:hover, .btn-flecha:hover:not(.desactivado) {
    transform: scale(1.25);
  }
</style>

<script>
  const inicializarMenuDerecho = () => {
    const menuContainer = document.querySelector('.menu-interactivo-numeros');
    if (!menuContainer) return;

    const paginaInicial = parseInt(menuContainer.getAttribute('data-pagina-inicial') || '1', 10);

    const btnArriba = document.getElementById('btn-arriba');
    const btnAbajo = document.getElementById('btn-abajo');
    const grupo1 = document.getElementById('grupo-numeros-1');
    const grupo2 = document.getElementById('grupo-numeros-2');

    if (!btnArriba || !btnAbajo || !grupo1 || !grupo2) return;

    let paginaActualMenu = paginaInicial;

    // Función que actualiza lo que se ve en pantalla
    const actualizarVistaMenu = () => {
      if (paginaActualMenu === 1) {
        grupo1.classList.remove('oculto');
        grupo2.classList.add('oculto');
        
        btnArriba.classList.add('desactivado'); // Bloqueamos ir más arriba del 0
        btnAbajo.classList.remove('desactivado'); // Permitimos bajar al 5-9
      } else {
        grupo1.classList.add('oculto');
        grupo2.classList.remove('oculto');
        
        btnArriba.classList.remove('desactivado'); // Permitimos subir al 0-4
        btnAbajo.classList.add('desactivado'); // Bloqueamos ir más abajo del 9
      }
    };

    // Ejecutamos la lógica al cargar la página
    actualizarVistaMenu();

    // Eventos de clic que NO recargan la página, solo cambian las imágenes
    btnArriba.addEventListener('click', () => {
      if (paginaActualMenu === 2) {
        paginaActualMenu = 1;
        actualizarVistaMenu();
      }
    });

    btnAbajo.addEventListener('click', () => {
      if (paginaActualMenu === 1) {
        paginaActualMenu = 2;
        actualizarVistaMenu();
      }
    });
  };

  document.addEventListener("DOMContentLoaded", inicializarMenuDerecho);
  document.addEventListener("astro:page-load", inicializarMenuDerecho);
</script>