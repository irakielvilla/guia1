---
// import Swiper JS
import Swiper from 'swiper';
// import Swiper styles
import 'swiper/css';
// Recibimos los datos como parámetros
// const { videos } = Astro.props;
// Recibimos los datos
const { miejercicio } = Astro.props;

// ESTO ES PARA DEPURAR: Verás el resultado en la terminal de VS Code
console.log("Datos recibidos en Pizarra:", miejercicio);
// ESTA ES LA CLAVE: Si miejercicio no existe, creamos uno vacío 
// para que el build no se rompa
if (!miejercicio) {
  return Astro.redirect('/'); 
  // O simplemente: const miejercicio = { video: '', titulo: '', instruccion: '' };
}
---
<div id="pizarracomp">
    <div class="pizarraprincipal">
        <video id="video-p" src={miejercicio.video} autoplay muted playsinline controls> </video>
        <div id="bordeazul"> </div>
    </div>
</div>
<div id="contenedor-info">
        <p set:html={miejercicio.instruccion}></p>
</div>

<style>
.pizarraprincipal{
    background-color: #ffffff;
    border-radius: 20px; 
/* border: 20px solid #188AE3; */
box-sizing: border-box;


display: flex;
justify-content: center;
align-items: center;
overflow: hidden;
position: relative;

width: 100%;
height: 100%;
}

.pizarraprincipal video{
    width: 101%;
    height: auto;
}

#pizarracomp{
    background-color: #83D3FF;
    grid-column: 7/26;
    grid-row: 5/14;
    z-index: 3;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20px;
    margin: 22px 20px 20px 22px;
    border-radius: 20px;
}

video {
  width: 100% !important;
  height: auto !important;
  min-height: 300px; /* Dale una altura mínima para ver si aparece */
}

#contenedor-info{
    grid-row: 6/13;
    grid-column: 7/13;
    background-color: #188ae3;
    z-index: 5;;
    padding-top: 40px;
    border-radius: 0px 54px 54px 0px;
    margin: 42px 35px 41px 42px;
    border-top: 5.9px solid #0468AD;
    border-right: 5.9px solid #0468AD;
    border-bottom: 5.9px solid #0468AD;
    

    
}
#contenedor-info p{
    font-family: 'Fredoka', sans-serif;
    font-weight: 300;
    color: #ffffff;
    text-align: center;
    padding-left: 16px;
    padding-right: 52px;
    font-size: 10.8pt;
    letter-spacing: -0.4px;
    line-height: 1.35;
    text-align: left;
}

</style>
