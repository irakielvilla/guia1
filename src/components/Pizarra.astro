---
// import Swiper JS
import Swiper from 'swiper';
// import Swiper styles
import 'swiper/css';
// Recibimos los datos como parámetros
// const { videos } = Astro.props;
// Recibimos los datos
const { miejercicio } = Astro.props;

// ESTO ES PARA DEPURAR: Verás el resultado en la terminal de VS Code
console.log("Datos recibidos en Pizarra:", miejercicio);
// ESTA ES LA CLAVE: Si miejercicio no existe, creamos uno vacío 
// para que el build no se rompa
if (!miejercicio) {
  return Astro.redirect('/'); 
  // O simplemente: const miejercicio = { video: '', titulo: '', instruccion: '' };
}
---
<div id="pizarracomp">
    <div class="pizarraprincipal">
    <video id="video-p" src={miejercicio.video} autoplay muted playsinline controls> </video>
    <div id="bordeazul">
    </div>
    </div>
</div>

<style>
.pizarraprincipal{
    background-color: #ffffff;
    border-radius: 20px; 
/* border: 20px solid #188AE3; */
box-sizing: border-box;


display: flex;
justify-content: center;
align-items: center;
overflow: hidden;
position: relative;

width: 100%;
height: 100%;
}

.pizarraprincipal video{
    width: 101%;
    height: auto;
}

#pizarracomp{
    background-color: #83D3FF;
    grid-column: 6/24;
    grid-row: 5/14;
    z-index: 3;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20px;
    margin: 20px;
    border-radius: 20px;
}

video {
  width: 100% !important;
  height: auto !important;
  min-height: 300px; /* Dale una altura mínima para ver si aparece */
}

</style>
