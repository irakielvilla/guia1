<style>
  .fondob {
    position: absolute;
  }
  .arribab {
    position: absolute;
    z-index: 6;
    width: 77%;
    
  }

  .fondobajo {
    position: absolute;
    width: 84%;
  }
  .abajob {
    position: absolute;
    z-index: 6;
    width: 60%;
  }

  #navegadorpasos {
    justify-content: space-between;
    display: flex;
    align-items: center;
    flex-direction: column;
    grid-column: 22/24;
    grid-row: 7/12;
    width: 100%;
    z-index: 5;
    margin-top: 80%;
    margin-bottom: 80%;
  }

  .navegador-btn {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 66%;
    height: 100%%;
    position: relative;
  }

  .pizarraprincipal {
    display: flex;
    background-color: #F2E9C7;
    border-radius: 20px;
    /* border: 20px solid #188AE3; */
    box-sizing: border-box;
    overflow: hidden;
    position: relative;
    width: 100%;
    height: 100%;
    justify-content: center;
    align-items: center;
  }
  #fondoazulinfo {
    background-color: #0668A9;
    grid-row: 5/14;
    grid-column: 7/23;
    z-index: 4;
    margin: 5.5% 0px 5.5% 5.5%;
    border-radius: 20px;
  }

  #pizarracomp {
    background-color: #F4DB74;
    grid-column: 7/26;
    grid-row: 5/14;
    z-index: 3;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20px;
    margin: 2.38%;
    border-radius: 20px;
  }

  video {
    overflow: hidden;
  }

  #contenedor-info {
    grid-row: 6/13;
    grid-column: 7/13;
    background-color: #E0B812;
    z-index: 5;
    padding-top: 40px;
    border-radius: 0px 54px 54px 0px;
    margin: 15% 13% 15% 15%;
    border-top: 5.9px solid #AA8B0B;
    border-right: 5.9px solid #AA8B0B;
    border-bottom: 5.9px solid #AA8B0B;
  }
  #contenedor-info p {
    font-family: "Fredoka", sans-serif;
    font-weight: 300;
    color: #ffffff;
    text-align: center;
    padding-left: 14%;
    padding-right: 13.4%;
    font-size: 95%;
    letter-spacing: -0.1%;
    line-height: 130%;
    text-align: left;
  }

  #pizarrabase {
    border-radius: 50px;
    grid-column: 6/27;
    grid-row: 4/15;
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 40px;
  }

  .esquinas {
    width: 100%;
    height: 100%;
    object-fit: fill;
  }


  #repro {
    margin-top: 48%;
    margin-bottom: 40%;
    grid-row: 7/12;
    grid-column: 25/27;
    display: flex;
    z-index: 1;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    row-gap: 2.5%;
  }


  .reprod {
    width: 100%;
  }

  .reprod:hover {
    transform: scale(1.25);
  }

  #decorepro {
    width: 65%;
    margin-bottom: 4%;
  }

  .reprodd {
    width: 100%;
        }

        #Pestanatitulo {
            margin-left:8.8%;
            margin-right: 8.8%;
            grid-column: 17/27;
            grid-row: 4/6;
            max-width: 100%;
        }

  
</style>

<script>
  const inicializarVideo = () => {
    const video =
      (document.getElementById("video-p") as HTMLVideoElement) ||
      document.querySelector("video");
    const btnPlay = document.getElementById("btn-play-pausa");
    const btnReplay = document.getElementById("btn-replay");

    console.log("--- Reporte de Conexión ---");
    console.log("Video encontrado:", !!video);
    console.log("Botón Play encontrado:", !!btnPlay);
    console.log("Botón Replay encontrado:", !!btnReplay);

    if (video && btnPlay && btnReplay) {
      btnPlay.onclick = () => {
        if (video.paused) {
          video.play();
          console.log("▶️ Reproduciendo...");
        } else {
          video.pause();
          console.log("⏸️ Pausado.");
        }
      };

      btnReplay.onclick = () => {
        video.currentTime = 0;
        video.play();
        console.log("🔄 Replay activado.");
      };

      console.log("✅ ¡Todo listo! Los botones ya controlan el video.");
    } else {
      console.error(
        "❌ Error: No se pudo establecer la conexión. Revisa que los IDs coincidan."
      );
    }
  };

  // Ejecución inmediata al cargar el componente
  inicializarVideo();

  // Refuerzo: Astro a veces necesita un pequeño respiro para juntar los componentes
  setTimeout(inicializarVideo, 500);
</script>
